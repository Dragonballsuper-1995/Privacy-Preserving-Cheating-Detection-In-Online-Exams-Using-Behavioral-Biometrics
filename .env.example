# Production Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
DB_NAME=cheating_detector
DB_USER=cheating_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# Security - CRITICAL: Change these in production!
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Environment
ENVIRONMENT=production
DEBUG=false

# CORS - Add your domain
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Admin Credentials
ADMIN_EMAIL=admin@cheatingdetector.com
ADMIN_PASSWORD=admin123

# Monitoring (Optional)
SENTRY_DSN=
GRAFANA_PASSWORD=

# Generate secure passwords:
# openssl rand -base64 32
# python -c "import secrets; print(secrets.token_urlsafe(32))"
